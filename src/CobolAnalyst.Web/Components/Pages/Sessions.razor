@page "/sessions"
@rendermode InteractiveServer
@using CobolAnalyst.Web.Core.Export
@using CobolAnalyst.Web.Core.State
@inject SessionStore SessionStore
@inject AnalysisStateService State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject WordDocumentExporter WordExporter

<PageTitle>CobolAnalyst — Sessions</PageTitle>

<div class="panel" style="height:calc(100vh - 52px);">
    <div class="page-header">Saved Sessions</div>

    @if (_loading)
    {
        <p style="color:var(--text-secondary);">Loading…</p>
    }
    else if (_sessions.Count == 0)
    {
        <div class="empty-state">
            <h3>No sessions yet</h3>
            <p>Run an analysis on the <a href="/">Analyst page</a> to create a session.</p>
        </div>
    }
    else
    {
        <div class="sessions-grid">
            @foreach (var s in _sessions)
            {
                <div class="session-card @(_loadingId == s.Id ? "sc-loading" : "")">
                    <div class="sc-header">
                        <span class="sc-name" title="@s.Name">@s.Name</span>
                        <span class="sc-rules-badge">@s.RuleCount rules</span>
                        <button class="btn-icon-delete" title="Delete session"
                                @onclick="() => PromptDelete(s.Id)"
                                disabled="@(_loadingId is not null)">&#x1F5D1;</button>
                    </div>

                    <div class="sc-meta">
                        <span>@s.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</span>
                        <span>@s.FileCount file@(s.FileCount != 1 ? "s" : "")</span>
                    </div>

                    @if (s.RuleCount > 0)
                    {
                        <div class="sc-decisions">
                            <span class="scd-accepted" title="Accepted">✓ @s.AcceptedCount</span>
                            <span class="scd-rejected" title="Rejected">✗ @s.RejectedCount</span>
                            <span class="scd-flagged"  title="Flagged">⚑ @s.FlaggedCount</span>
                            <span class="scd-pending"  title="Pending">@s.PendingCount pending</span>
                        </div>
                    }

                    @if (_confirmDeleteId == s.Id)
                    {
                        <div class="sc-delete-confirm">
                            <span>Delete this session? This cannot be undone.</span>
                            <div class="sc-delete-actions">
                                <button class="btn btn-danger btn-sm" @onclick="() => ConfirmDelete(s.Id)">Delete</button>
                                <button class="btn btn-sm" @onclick="CancelDelete">Cancel</button>
                            </div>
                        </div>
                    }

                    <button class="btn btn-primary btn-sm sc-load-btn"
                            @onclick="() => LoadSession(s.Id)"
                            disabled="@(_loadingId is not null || _confirmDeleteId is not null)">
                        @(_loadingId == s.Id ? "Loading…" : "Load Session")
                    </button>
                    <button class="btn btn-sm sc-load-btn"
                            @onclick="() => ExportWordDoc(s.Id)"
                            disabled="@(_loadingId is not null || _confirmDeleteId is not null || _exportingId is not null)"
                            style="margin-top:6px;">
                        @(_exportingId == s.Id ? "Exporting…" : "⬇ Export Report")
                    </button>
                </div>
            }
        </div>
    }

    @if (_toastMessage is not null)
    {
        <div class="toast-msg">@_toastMessage</div>
    }

    @if (_errorMessage is not null)
    {
        <div class="error-msg">@_errorMessage</div>
    }
</div>

@code {
    private List<SessionSummary> _sessions = [];
    private bool _loading = true;
    private string? _loadingId;
    private string? _exportingId;
    private string? _errorMessage;
    private string? _confirmDeleteId;
    private string? _toastMessage;
    private System.Threading.Timer? _toastTimer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _sessions = await SessionStore.ListAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load sessions: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadSession(string id)
    {
        _loadingId    = id;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var session = await SessionStore.LoadAsync(id);
            if (session is null)
            {
                _errorMessage = "Session could not be found on disk.";
                return;
            }

            // Restore session into the circuit-scoped state service so the
            // Analyst page picks it up on navigation without re-analysing.
            State.Session     = session;
            State.SessionName = session.Name;
            State.NotifyChanged();

            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load session: {ex.Message}";
        }
        finally
        {
            _loadingId = null;
        }
    }

    private async Task ExportWordDoc(string sessionId)
    {
        _exportingId = sessionId;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var session = await SessionStore.LoadAsync(sessionId);
            if (session is null)
            {
                _errorMessage = "Session could not be loaded for export.";
                return;
            }

            var bytes = WordExporter.GenerateReport(session);
            var base64 = Convert.ToBase64String(bytes);
            var safeName = string.Concat(
                session.Name.Select(c => char.IsLetterOrDigit(c) || c == '-' ? c : '_'));
            var fileName = $"{safeName}_analysis_{DateTime.Now:yyyyMMdd}.docx";

            await JS.InvokeVoidAsync("downloadBinaryFile", fileName, base64,
                "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            _exportingId = null;
            StateHasChanged();
        }
    }

    private void PromptDelete(string id)
    {
        _confirmDeleteId = id;
        _errorMessage = null;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        _confirmDeleteId = null;
        StateHasChanged();
    }

    private async Task ConfirmDelete(string id)
    {
        _confirmDeleteId = null;
        _errorMessage = null;

        var ok = await SessionStore.DeleteSessionAsync(id);
        if (ok)
        {
            _sessions.RemoveAll(s => s.Id == id);

            // If the active circuit session was the deleted one, clear state.
            if (State.Session?.Id == id)
                State.Clear();

            ShowToast("Session deleted.");
        }
        else
        {
            _errorMessage = "Could not delete session — it may have already been removed.";
        }

        StateHasChanged();
    }

    private void ShowToast(string message)
    {
        _toastMessage = message;
        _toastTimer?.Dispose();
        _toastTimer = new System.Threading.Timer(_ =>
        {
            _toastMessage = null;
            _toastTimer?.Dispose();
            _toastTimer = null;
            InvokeAsync(StateHasChanged);
        }, null, 2000, System.Threading.Timeout.Infinite);
    }
}
