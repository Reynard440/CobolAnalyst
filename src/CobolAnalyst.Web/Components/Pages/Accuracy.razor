@page "/accuracy"
@rendermode InteractiveServer
@implements IDisposable
@using CobolAnalyst.Web.Core.State
@using CobolAnalyst.Web.Core.Validation
@using CobolAnalyst.Web.Core.Sessions
@using CobolAnalyst.Web.Core.Prompts
@using CobolAnalyst.Web.Core.Llm
@using CobolAnalyst.Web.Models
@using Microsoft.AspNetCore.Components.Forms
@using System.Text

@inject AnalysisStateService  State
@inject SessionStore          SessionStore
@inject ValidationService     Validator
@inject ValidationStore       ValStore
@inject GroundTruthParser     Parser
@inject PromptTemplateStore   Templates
@inject ILlmClient            LlmClient
@inject IJSRuntime            JS

<PageTitle>CobolAnalyst — Accuracy</PageTitle>

<div class="analyst-layout">

    <!-- ═══════════════════════════════ LEFT SIDEBAR ══════════════════════════ -->
    <aside class="sidebar">

        <!-- Session selector -->
        <div class="sidebar-section">
            <span class="sidebar-label">Session</span>
            <select class="model-select" value="@_selectedSessionId" @onchange="OnPrimarySessionChanged" disabled="@_running">
                <option value="">— pick a session —</option>
                @foreach (var s in _sessions)
                {
                    <option value="@s.Id">@s.Name (@s.RuleCount rules)</option>
                }
            </select>
        </div>

        <!-- Ground truth section -->
        <div class="sidebar-section">
            <span class="sidebar-label">Ground Truth</span>

            <!-- Mode pills -->
            <div class="gt-mode-pills">
                <button class="gt-mode-pill @(_gtMode == GtMode.Type     ? "active" : "")" @onclick='() => SwitchMode(GtMode.Type)'     disabled="@_running" type="button">Type</button>
                <button class="gt-mode-pill @(_gtMode == GtMode.Upload   ? "active" : "")" @onclick='() => SwitchMode(GtMode.Upload)'   disabled="@_running" type="button">Upload</button>
                <button class="gt-mode-pill @(_gtMode == GtMode.Generate ? "active" : "")" @onclick='() => SwitchMode(GtMode.Generate)' disabled="@_running" type="button">Generate</button>
                <button class="gt-mode-pill @(_gtMode == GtMode.Compare  ? "active" : "")" @onclick='() => SwitchMode(GtMode.Compare)'  disabled="@_running" type="button">Compare</button>
            </div>

            <!-- ── TYPE mode ── -->
            @if (_gtMode == GtMode.Type)
            {
                <div class="gt-inline-header">
                    <span style="font-size:11px;color:var(--text-3);">One rule per line</span>
                    @if (!string.IsNullOrEmpty(_typedText))
                    {
                        <button class="acc-clear-btn" @onclick="ClearTypedText" type="button">✕ Clear</button>
                    }
                </div>
                <textarea class="gt-textarea"
                          rows="12"
                          placeholder="# One rule per line. Format:&#10;# GT-001 | Category | Rule description&#10;#&#10;GT-001 | Calculations | Overtime is paid at 1.5x for hours beyond 40&#10;GT-002 | Validations | Employee ID must be numeric and 6 digits&#10;GT-003 | Constraints | Max order quantity must not exceed MAX-ORDER-QTY"
                          @bind="_typedText"
                          @bind:event="oninput"
                          @bind:after="RefreshTypedRules"
                          disabled="@_running"
                          style="min-height:180px;"></textarea>
                @if (_typedRules.Count > 0)
                {
                    <span class="gt-parse-feedback gt-parse-ok">✓ @_typedRules.Count rule@(_typedRules.Count == 1 ? "" : "s") parsed</span>
                }
                else if (!string.IsNullOrWhiteSpace(_typedText))
                {
                    <span class="gt-parse-feedback gt-parse-warn">⚠ No valid rules found</span>
                }
            }

            <!-- ── UPLOAD mode ── -->
            else if (_gtMode == GtMode.Upload)
            {
                <label class="gt-upload-zone">
                    <InputFile OnChange="OnFileSelected" accept=".txt,.docx,.doc" disabled="@_running" />
                    @if (_gtRules.Count == 0 && !_parsing)
                    {
                        <div class="upload-icon">&#x1F4C4;</div>
                        <p class="upload-hint">Drop or click to upload</p>
                        <p class="upload-hint-sub">.txt &nbsp;·&nbsp; .docx &nbsp;·&nbsp; .doc</p>
                        <p class="upload-hint-sub">Format: <code>ID | Category | Rule text</code></p>
                    }
                    else if (_parsing)
                    {
                        <div class="upload-icon">&#x23F3;</div>
                        <p class="upload-hint">Parsing file…</p>
                    }
                    else
                    {
                        <div class="upload-icon">&#x2705;</div>
                        <p class="upload-success">@_gtRules.Count rule@(_gtRules.Count == 1 ? "" : "s") extracted from @_gtFileName</p>
                        <button class="acc-clear-btn" @onclick="ClearGroundTruth" type="button" disabled="@_running">&#x2715; Clear</button>
                    }
                </label>
                @if (_parseError is not null)
                {
                    <div class="error-msg" style="margin-top:6px;">@_parseError</div>
                }
            }

            <!-- ── GENERATE mode ── -->
            else if (_gtMode == GtMode.Generate)
            {
                <button class="btn btn-primary"
                        style="width:100%;"
                        @onclick="GenerateGroundTruth"
                        disabled="@(!CanGenerate)"
                        title="@(string.IsNullOrEmpty(_selectedSessionId) ? "Select a session first" : "")"
                        type="button">
                    @(_generating ? "⏳ Generating…" : "✨ Generate Ground Truth")
                </button>

                @if (!string.IsNullOrEmpty(_generateStatus))
                {
                    <p class="gt-parse-feedback @(_generateStatus.StartsWith("✓") ? "gt-parse-ok" : "gt-parse-warn")"
                       style="margin-top:6px;">@_generateStatus</p>
                }

                @if (!string.IsNullOrEmpty(_generateText) || _generating)
                {
                    <div class="gt-inline-header" style="margin-top:8px;">
                        <span style="font-size:11px;color:var(--text-3);">Review and edit before validating</span>
                    </div>
                    <textarea class="gt-textarea"
                              rows="12"
                              @bind="_generateText"
                              @bind:event="oninput"
                              @bind:after="RefreshGenerateRules"
                              disabled="@(_running || _generating)"
                              style="min-height:180px;"></textarea>
                    @if (_generateRules.Count > 0)
                    {
                        <span class="gt-parse-feedback gt-parse-ok">✓ @_generateRules.Count rule@(_generateRules.Count == 1 ? "" : "s") parsed</span>
                    }
                }
            }

            <!-- ── COMPARE mode ── -->
            else if (_gtMode == GtMode.Compare)
            {
                <span style="font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:0.8px;">Use as Ground Truth:</span>
                <select class="model-select" @onchange="OnRefSessionChanged" disabled="@_running">
                    <option value="">— select reference session —</option>
                    @foreach (var s in _sessions.Where(s => s.Id != _selectedSessionId))
                    {
                        <option value="@s.Id">@s.Name — @s.AcceptedCount accepted · @s.CreatedAt.ToString("MM-dd")</option>
                    }
                </select>

                @if (!string.IsNullOrEmpty(_refSessionId))
                {
                    @if (_refRuleCount == 0)
                    {
                        <div class="error-msg" style="font-size:11.5px;margin-top:4px;">
                            ⚠ No accepted rules in this session — accept some rules first or choose a different session.
                        </div>
                    }
                    else
                    {
                        <span class="gt-parse-feedback gt-parse-ok">✓ @_refRuleCount rule@(_refRuleCount == 1 ? "" : "s") will be used as ground truth</span>
                    }
                    <label style="font-size:11.5px;color:var(--text-2);display:flex;align-items:center;gap:6px;margin-top:6px;cursor:pointer;">
                        <input type="checkbox" @bind="_includeFlagged" @bind:after="RefreshRefRules" style="accent-color:var(--brand);width:14px;height:14px;" />
                        Include Flagged rules
                    </label>
                }
            }
        </div>

        <!-- Threshold slider -->
        <div class="sidebar-section">
            <span class="sidebar-label">Similarity Threshold: @_threshold.ToString("F2")</span>
            <input type="range" min="0.10" max="0.90" step="0.05"
                   @bind="_threshold" @bind:event="oninput"
                   style="width:100%;accent-color:var(--accent-blue);"
                   disabled="@_running" />
            <small style="color:var(--text-secondary);">LCS similarity required for a TP match</small>
        </div>

        <!-- Run button -->
        <div class="sidebar-section">
            <button class="btn btn-primary" @onclick="RunValidation"
                    disabled="@(!CanRun)"
                    title="@RunButtonTooltip">
                @(_running ? "Running…" : "▶  Run Validation")
            </button>
        </div>

        @if (_globalError is not null)
        {
            <div class="error-msg">@_globalError</div>
        }

    </aside>

    <!-- ═══════════════════════════════ RIGHT PANEL ═══════════════════════════ -->
    <section class="panel">

        @if (_result is null && !_running)
        {
            <div class="empty-state acc-empty">
                <div class="acc-empty-icon">&#x1F4CA;</div>
                <h3>Accuracy Dashboard</h3>
                <p>Select a session, provide ground truth rules, then click <strong>Run Validation</strong>.</p>
                <div class="acc-format-box">
                    <p class="acc-format-title">Ground truth .txt format</p>
                    <pre class="acc-format-pre"># Comment lines start with #
GT-001 | Calculation  | Hours beyond 40/week paid at 1.5× rate.
GT-002 | Validation   | Employee ID must be numeric and 6 digits.
GT-003 | Constraint   | Max order quantity must not exceed MAX-ORDER-QTY.</pre>
                </div>
            </div>
        }
        else if (_running)
        {
            <div class="empty-state"><p>Running validation…</p></div>
        }
        else if (_result is not null)
        {
            <!-- ── Result header ── -->
            <div class="page-header">
                Accuracy Report
                <span class="acc-run-meta">
                    @_result.SessionName &bull; @_result.RunAt.ToString("yyyy-MM-dd HH:mm") UTC
                    @if (!string.IsNullOrEmpty(_result.ModelName))
                    {<span> &bull; @_result.ModelName</span>}
                </span>
            </div>

            @if (!string.IsNullOrEmpty(_gtSourceDescriptor))
            {
                <div class="acc-gt-source">
                    Ground truth source: <strong>@_gtSourceDescriptor</strong>
                    @if (_showSave)
                    {
                        <button class="acc-clear-btn" style="margin-left:10px;" @onclick="SaveGroundTruthAsFile" type="button">⬇ Save as .txt</button>
                    }
                </div>
            }

            <!-- ── Metric chips ── -->
            <div class="metrics-header">
                <div class="metric-chip metric-precision">
                    <span class="metric-value">@_result.Precision.ToString("P0")</span>
                    <span class="metric-label">Precision</span>
                </div>
                <div class="metric-chip metric-recall">
                    <span class="metric-value">@_result.Recall.ToString("P0")</span>
                    <span class="metric-label">Recall</span>
                </div>
                <div class="metric-chip metric-f1">
                    <span class="metric-value">@_result.F1.ToString("P0")</span>
                    <span class="metric-label">F1</span>
                </div>
                <div class="metric-chip metric-tp">
                    <span class="metric-value">@_result.TpCount</span>
                    <span class="metric-label">True Pos</span>
                </div>
                <div class="metric-chip metric-fp">
                    <span class="metric-value">@_result.FpCount</span>
                    <span class="metric-label">False Pos</span>
                </div>
                <div class="metric-chip metric-fn">
                    <span class="metric-value">@_result.FnCount</span>
                    <span class="metric-label">False Neg</span>
                </div>
                <div class="metric-chip metric-gt">
                    <span class="metric-value">@_result.GroundTruthCount</span>
                    <span class="metric-label">GT Rules</span>
                </div>
            </div>

            <!-- ── Tab strip ── -->
            <div class="tab-strip">
                @foreach (var tab in Tabs)
                {
                    <button class="tab-btn @(_activeTab == tab ? "active" : "")"
                            @onclick="() => _activeTab = tab">
                        @tab
                        @if (tab == "Matched"         && _result.TpCount > 0) { <span class="tab-badge tab-badge-tp">@_result.TpCount</span> }
                        @if (tab == "False Positives" && _result.FpCount > 0) { <span class="tab-badge tab-badge-fp">@_result.FpCount</span> }
                        @if (tab == "False Negatives" && _result.FnCount > 0) { <span class="tab-badge tab-badge-fn">@_result.FnCount</span> }
                        @if (tab == "History"         && _history.Count > 0)  { <span class="tab-badge tab-badge-hist">@_history.Count</span> }
                    </button>
                }
            </div>

            <!-- ── Tab content ── -->
            <div class="tab-content">

                @if (_activeTab == "Overview")
                {
                    @if (_result.ByCategory.Count > 0)
                    {
                        <!-- Inline SVG bar chart: F1 per category -->
                        <div class="acc-chart-wrap">
                            <p class="acc-chart-title">F1 score by category</p>
                            @RenderBarChart()
                        </div>

                        <table class="data-table" style="margin-top:12px;">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th class="num">TP</th>
                                    <th class="num">FP</th>
                                    <th class="num">FN</th>
                                    <th class="num">Precision</th>
                                    <th class="num">Recall</th>
                                    <th class="num">F1</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in _result.ByCategory.OrderByDescending(c => c.F1))
                                {
                                    <tr>
                                        <td>@cat.Category</td>
                                        <td class="num">@cat.TruePositives</td>
                                        <td class="num">@cat.FalsePositives</td>
                                        <td class="num">@cat.FalseNegatives</td>
                                        <td class="num">@cat.Precision.ToString("P0")</td>
                                        <td class="num">@cat.Recall.ToString("P0")</td>
                                        <td class="num f1-cell @F1Class(cat.F1)">@cat.F1.ToString("P0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state" style="padding:24px 0;">
                            <p>No category breakdown — run validation with at least one extracted rule and one GT rule.</p>
                        </div>
                    }
                }

                else if (_activeTab == "Matched")
                {
                    @if (_result.TruePositives.Count == 0)
                    {
                        <div class="empty-state"><p>No matched pairs — every extracted rule fell below the similarity threshold.</p></div>
                    }
                    else
                    {
                        @foreach (var m in _result.TruePositives.OrderByDescending(p => p.Similarity))
                        {
                            <div class="match-card tp-card">
                                <div class="match-row">
                                    <span class="match-tag match-extracted">Extracted</span>
                                    <strong>@m.Extracted.Label</strong>
                                    <span class="badge">@m.Extracted.Type</span>
                                    <span class="sim-badge">sim @m.Similarity.ToString("F2")</span>
                                </div>
                                <p class="match-desc">@m.Extracted.Description</p>
                                <div class="match-row" style="margin-top:6px;">
                                    <span class="match-tag match-gt">Ground Truth</span>
                                    <strong>@m.GroundTruth.Id</strong>
                                    <span class="badge">@m.GroundTruth.Category</span>
                                </div>
                                <p class="match-desc">@m.GroundTruth.RuleText</p>
                            </div>
                        }
                    }
                }

                else if (_activeTab == "False Positives")
                {
                    @if (_result.FalsePositives.Count == 0)
                    {
                        <div class="empty-state"><p>No false positives — every extracted rule matched a ground truth entry.</p></div>
                    }
                    else
                    {
                        @foreach (var fp in _result.FalsePositives)
                        {
                            <div class="match-card fp-card">
                                <div class="match-row">
                                    <span class="badge">@fp.Rule.Type</span>
                                    <strong>@fp.Rule.Label</strong>
                                    <span class="badge">@fp.Rule.Confidence</span>
                                </div>
                                <p class="match-desc">@fp.Rule.Description</p>
                                <p class="match-reason"><span class="reason-icon">&#x26A0;</span> @fp.Reason</p>
                            </div>
                        }
                    }
                }

                else if (_activeTab == "False Negatives")
                {
                    @if (_result.FalseNegatives.Count == 0)
                    {
                        <div class="empty-state"><p>No false negatives — all ground truth rules were matched.</p></div>
                    }
                    else
                    {
                        @foreach (var fn in _result.FalseNegatives)
                        {
                            <div class="match-card fn-card">
                                <div class="match-row">
                                    <span class="badge">@fn.Rule.Category</span>
                                    <strong>@fn.Rule.Id</strong>
                                    @if (!string.IsNullOrEmpty(fn.Rule.SourceRef))
                                    {<span class="match-source">@fn.Rule.SourceRef</span>}
                                </div>
                                <p class="match-desc">@fn.Rule.RuleText</p>
                                <p class="match-reason"><span class="reason-icon">&#x2139;</span> @fn.Reason</p>
                            </div>
                        }
                    }
                }

                else if (_activeTab == "History")
                {
                    @if (_history.Count == 0)
                    {
                        <div class="empty-state"><p>No previous validation runs saved yet.</p></div>
                    }
                    else
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Session</th>
                                    <th class="num">GT</th>
                                    <th class="num">TP</th>
                                    <th class="num">FP</th>
                                    <th class="num">FN</th>
                                    <th class="num">Precision</th>
                                    <th class="num">Recall</th>
                                    <th class="num">F1</th>
                                    <th class="num">Thresh</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in _history)
                                {
                                    <tr class="@(_result?.Id == h.Id ? "history-current" : "")">
                                        <td>@h.RunAt.ToString("MM-dd HH:mm")</td>
                                        <td>@h.SessionName</td>
                                        <td class="num">@h.GroundTruthCount</td>
                                        <td class="num">@h.TpCount</td>
                                        <td class="num">@h.FpCount</td>
                                        <td class="num">@h.FnCount</td>
                                        <td class="num">@h.Precision.ToString("P0")</td>
                                        <td class="num">@h.Recall.ToString("P0")</td>
                                        <td class="num f1-cell @F1Class(h.F1)">@h.F1.ToString("P0")</td>
                                        <td class="num">@h.Threshold.ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }

                else if (_activeTab == "Guidance")
                {
                    <div class="guidance-list">
                        @foreach (var item in _result.GuidanceItems)
                        {
                            <div class="guidance-item">
                                <span class="guidance-icon">&#x2139;</span>
                                <span>@item</span>
                            </div>
                        }
                    </div>
                }

            </div><!-- /tab-content -->
        }

    </section>
</div>

@code {

    // ── Mode enum ─────────────────────────────────────────────────────────────
    private enum GtMode { Type, Upload, Generate, Compare }

    // ── Tab list ──────────────────────────────────────────────────────────────
    private static readonly string[] Tabs =
        ["Overview", "Matched", "False Positives", "False Negatives", "History", "Guidance"];

    // ── RuleType → GT category map (for Compare mode) ─────────────────────────
    private static readonly Dictionary<RuleType, string> TypeToCategory = new()
    {
        [RuleType.BusinessRule]       = "BusinessRule",
        [RuleType.Validation]         = "Validation",
        [RuleType.Calculation]        = "Calculation",
        [RuleType.DataTransformation] = "DataMapping",
        [RuleType.ControlFlow]        = "WorkflowControl",
    };

    // ── Core state ────────────────────────────────────────────────────────────
    private List<SessionSummary>    _sessions          = [];
    private string                  _selectedSessionId = "";
    private float                   _threshold         = 0.40f;
    private bool                    _running;
    private string?                 _globalError;
    private ValidationResult?       _result;
    private List<CobolAnalyst.Web.Models.ValidationSummary> _history = [];
    private string                  _activeTab         = "Overview";

    // ── Mode state ────────────────────────────────────────────────────────────
    private GtMode _gtMode = GtMode.Type;

    // Type mode
    private string                _typedText  = "";
    private List<GroundTruthRule> _typedRules = [];

    // Upload mode
    private List<GroundTruthRule> _gtRules    = [];
    private string                _gtFileName = "";
    private bool                  _parsing;
    private string?               _parseError;

    // Generate mode
    private string                _generateText   = "";
    private List<GroundTruthRule> _generateRules  = [];
    private bool                  _generating;
    private string?               _generateStatus;
    private bool                  _generateEdited;
    private CancellationTokenSource? _generateCts;

    // Compare mode
    private string                _refSessionId  = "";
    private bool                  _includeFlagged;
    private List<GroundTruthRule> _refRules      = [];
    private int                   _refRuleCount;
    private string                _refModelUsed  = "";

    // Result metadata
    private string  _gtSourceDescriptor  = "";
    private GtMode  _gtModeAtLastRun     = GtMode.Type;
    private bool    _showSave            => _result is not null &&
                                           (_gtModeAtLastRun == GtMode.Type || _gtModeAtLastRun == GtMode.Generate);

    // ── Computed CanRun ───────────────────────────────────────────────────────
    private bool CanRun =>
        !_running &&
        !string.IsNullOrEmpty(_selectedSessionId) &&
        ActiveModeHasRules;

    private bool ActiveModeHasRules => _gtMode switch
    {
        GtMode.Type     => _typedRules.Count > 0,
        GtMode.Upload   => _gtRules.Count > 0,
        GtMode.Generate => _generateRules.Count > 0,
        GtMode.Compare  => _refRuleCount > 0,
        _               => false
    };

    private bool CanGenerate => !_generating && !string.IsNullOrEmpty(_selectedSessionId);

    private string RunButtonTooltip
    {
        get
        {
            if (_running) return "";
            if (string.IsNullOrEmpty(_selectedSessionId)) return "Select a session";
            if (!ActiveModeHasRules) return _gtMode switch
            {
                GtMode.Type     => "Enter at least one rule",
                GtMode.Upload   => "Upload a ground truth file",
                GtMode.Generate => "Generate ground truth first",
                GtMode.Compare  => "Reference session has no accepted rules",
                _               => ""
            };
            return "";
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _sessions = await SessionStore.ListAsync();
        _history  = await ValStore.ListAsync();

        if (State.Session is not null && _sessions.Any(s => s.Id == State.Session.Id))
            _selectedSessionId = State.Session.Id;
    }

    public void Dispose()
    {
        _generateCts?.Cancel();
        _generateCts?.Dispose();
    }

    // ── Mode switching ────────────────────────────────────────────────────────

    private void SwitchMode(GtMode mode)
    {
        if (_gtMode == mode) return;
        if (_generating) { _generateCts?.Cancel(); }
        _gtMode = mode;
    }

    private void OnPrimarySessionChanged(ChangeEventArgs e)
    {
        var newId = e.Value?.ToString() ?? "";
        if (_refSessionId == newId)
        {
            _refSessionId = "";
            _refRules     = [];
            _refRuleCount = 0;
            _refModelUsed = "";
        }
        _selectedSessionId = newId;
    }

    // ── TYPE mode ─────────────────────────────────────────────────────────────

    private void RefreshTypedRules() => _typedRules = ParseInlineText(_typedText);

    private void ClearTypedText()
    {
        _typedText  = "";
        _typedRules = [];
    }

    // ── UPLOAD mode ───────────────────────────────────────────────────────────

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _parseError = null;
        _gtRules    = [];
        _gtFileName = "";
        _parsing    = true;
        StateHasChanged();

        try
        {
            var file    = e.File;
            _gtFileName = file.Name;

            const long MaxBytes = 10 * 1024 * 1024;
            await using var stream = file.OpenReadStream(MaxBytes);

            _gtRules = await Parser.ParseAsync(stream, file.Name);

            if (_gtRules.Count == 0)
                _parseError = "No rules found. Check the format: \"ID | Category | Rule text\".";
        }
        catch (Exception ex)
        {
            _parseError = $"Could not read file: {ex.Message}";
            _gtRules    = [];
        }
        finally
        {
            _parsing = false;
            StateHasChanged();
        }
    }

    private void ClearGroundTruth()
    {
        _gtRules    = [];
        _gtFileName = "";
        _parseError = null;
    }

    // ── GENERATE mode ─────────────────────────────────────────────────────────

    private void RefreshGenerateRules()
    {
        _generateRules = ParseInlineText(_generateText);
        if (_generateRules.Count > 0 && _generateStatus?.StartsWith("✓") == true)
            _generateEdited = true;
    }

    private async Task GenerateGroundTruth()
    {
        if (string.IsNullOrEmpty(_selectedSessionId)) return;

        var session = await SessionStore.LoadAsync(_selectedSessionId);
        if (session is null) return;

        if (session.SourceFiles.Count == 0 || !File.Exists(session.SourceFiles[0].PermanentPath))
        {
            _generateStatus = "Source file not available for this session. Use Type or Upload mode.";
            StateHasChanged();
            return;
        }

        _generating     = true;
        _generateText   = "";
        _generateRules  = [];
        _generateEdited = false;
        _generateStatus = "Reading source file and generating ground truth…";
        StateHasChanged();

        try
        {
            var sourceCode = await File.ReadAllTextAsync(session.SourceFiles[0].PermanentPath);

            var prompt =
                "You are a COBOL business analyst creating a ground truth rule list\n" +
                "for validation testing. Read the source code below and extract\n" +
                "every business rule, validation, calculation, data mapping,\n" +
                "workflow, and constraint that a thorough analyst should find.\n\n" +
                "Return ONLY a plain text list in this exact format, one rule per line:\n" +
                "GT-001 | Category | Rule description in plain English\n\n" +
                "Categories must be one of:\n" +
                "Business Rules, Validations, Calculations, Data Mappings,\n" +
                "Workflows, Constraints, Error Handling\n\n" +
                "Rules must describe business INTENT (what the system enforces),\n" +
                "not implementation details (how the code works).\n" +
                "Aim for completeness — it is better to include borderline rules\n" +
                "than to miss critical ones.\n\n" +
                "Source code:\n" + sourceCode + "\n\n" +
                "Return ONLY the GT-NNN | Category | Description lines. No preamble.";

            _generateCts = new CancellationTokenSource();
            var sb = new StringBuilder();

            await foreach (var token in LlmClient.StreamCompletionAsync(prompt, _generateCts.Token))
            {
                sb.Append(token);
                _generateText  = sb.ToString();
                _generateRules = ParseInlineText(_generateText);
                StateHasChanged();
            }

            _generateRules  = ParseInlineText(_generateText);
            _generateStatus = $"✓ {_generateRules.Count} rule{(_generateRules.Count == 1 ? "" : "s")} generated — review and edit before validating";
        }
        catch (OperationCanceledException)
        {
            _generateStatus = "Generation cancelled.";
        }
        catch (Exception ex)
        {
            _generateStatus = $"Error: {ex.Message}";
        }
        finally
        {
            _generating = false;
            _generateCts?.Dispose();
            _generateCts = null;
            StateHasChanged();
        }
    }

    // ── COMPARE mode ──────────────────────────────────────────────────────────

    private async Task OnRefSessionChanged(ChangeEventArgs e)
    {
        _refSessionId = e.Value?.ToString() ?? "";
        _refRules     = [];
        _refRuleCount = 0;
        _refModelUsed = "";

        if (!string.IsNullOrEmpty(_refSessionId))
            await RefreshRefRules();
    }

    private async Task RefreshRefRules()
    {
        if (string.IsNullOrEmpty(_refSessionId)) return;

        var session = await SessionStore.LoadAsync(_refSessionId);
        if (session is null) return;

        _refModelUsed = session.ModelUsed;
        _refRules     = MapSessionRulesToGroundTruth(session.Rules, _includeFlagged);
        _refRuleCount = _refRules.Count;
    }

    private static List<GroundTruthRule> MapSessionRulesToGroundTruth(
        List<ExtractedRule> rules, bool includeFlagged) =>
        rules
            .Where(r => r.Decision == ReviewDecision.Accepted
                     || (includeFlagged && r.Decision == ReviewDecision.Flagged))
            .Select(r => new GroundTruthRule
            {
                Id        = r.Id,
                Category  = TypeToCategory.GetValueOrDefault(r.Type, "BusinessRule"),
                RuleText  = r.Description,
                SourceRef = r.CobolReference
            })
            .ToList();

    // ── Run Validation ────────────────────────────────────────────────────────

    private async Task RunValidation()
    {
        _globalError = null;
        _result      = null;
        _running     = true;
        StateHasChanged();

        try
        {
            var session = await SessionStore.LoadAsync(_selectedSessionId);
            if (session is null) { _globalError = "Session not found on disk."; return; }

            // Collect ground truth from the active mode
            List<GroundTruthRule> groundTruth;
            switch (_gtMode)
            {
                case GtMode.Type:
                    groundTruth         = ParseInlineText(_typedText);
                    _gtSourceDescriptor = $"Typed inline — {groundTruth.Count} rule{(groundTruth.Count == 1 ? "" : "s")}";
                    break;

                case GtMode.Upload:
                    groundTruth         = _gtRules;
                    _gtSourceDescriptor = $"Uploaded — {_gtFileName} ({groundTruth.Count} rule{(groundTruth.Count == 1 ? "" : "s")})";
                    break;

                case GtMode.Generate:
                    groundTruth         = ParseInlineText(_generateText);
                    var editedTag       = _generateEdited ? " (edited)" : "";
                    _gtSourceDescriptor = $"Generated by LLM — {groundTruth.Count} rule{(groundTruth.Count == 1 ? "" : "s")}{editedTag}";
                    break;

                case GtMode.Compare:
                    groundTruth = _refRules;
                    var refSummary  = _sessions.FirstOrDefault(s => s.Id == _refSessionId);
                    var modelSuffix = string.IsNullOrEmpty(_refModelUsed) ? "" : $" / {_refModelUsed}";
                    _gtSourceDescriptor = $"Session comparison — {refSummary?.Name ?? _refSessionId}{modelSuffix} ({groundTruth.Count} rule{(groundTruth.Count == 1 ? "" : "s")})";
                    break;

                default:
                    return;
            }

            _gtModeAtLastRun = _gtMode;

            var template  = Templates.GetActive();
            var modelName = State.SelectedModel;

            var result = await Task.Run(() =>
                Validator.RunValidation(
                    session.Rules,
                    groundTruth,
                    _threshold,
                    sessionName: session.Name,
                    modelName:   modelName,
                    sessionId:   session.Id,
                    templateId:  template?.Id ?? ""));

            await ValStore.SaveAsync(result);

            if (template is not null)
            {
                Templates.RecordValidation(template.Id, new TemplateValidationRecord
                {
                    SessionId      = session.Id,
                    SessionName    = session.Name,
                    F1             = result.F1,
                    Precision      = result.Precision,
                    Recall         = result.Recall,
                    TruePositives  = result.TpCount,
                    FalsePositives = result.FpCount,
                    FalseNegatives = result.FnCount
                });
            }

            _result    = result;
            _history   = await ValStore.ListAsync();
            _activeTab = "Overview";
        }
        catch (Exception ex)
        {
            _globalError = $"Validation failed: {ex.Message}";
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    // ── Save ground truth as file ─────────────────────────────────────────────

    private async Task SaveGroundTruthAsFile()
    {
        var content  = _gtModeAtLastRun == GtMode.Generate ? _generateText : _typedText;
        var session  = _sessions.FirstOrDefault(s => s.Id == _selectedSessionId);
        var rawName  = session?.Name ?? "ground_truth";
        var safeName = string.Concat(rawName.Select(c =>
            char.IsLetterOrDigit(c) || c == '-' ? c : '_'));
        var fileName = $"{safeName}_ground_truth.txt";

        await JS.InvokeVoidAsync("downloadTextFile", fileName, content);
    }

    // ── Inline text parser (Type & Generate modes) ────────────────────────────

    private static List<GroundTruthRule> ParseInlineText(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return [];

        var rules      = new List<GroundTruthRule>();
        int lineNumber = 0;

        foreach (var rawLine in text.Split('\n'))
        {
            lineNumber++;
            var line = rawLine.Trim();
            if (string.IsNullOrEmpty(line) || line.StartsWith('#')) continue;

            var parts = line.Split('|');
            if (parts.Length >= 3)
            {
                var id       = parts[0].Trim();
                var category = parts[1].Trim();
                var ruleText = string.Join('|', parts[2..]).Trim();

                if (!string.IsNullOrEmpty(id) && !string.IsNullOrEmpty(ruleText))
                {
                    rules.Add(new GroundTruthRule { Id = id, Category = category, RuleText = ruleText });
                    continue;
                }
            }

            // Fallback: treat whole line as rule text
            rules.Add(new GroundTruthRule
            {
                Id       = $"GT-{lineNumber:D3}",
                Category = "Business Rules",
                RuleText = line
            });
        }

        return rules;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private MarkupString RenderBarChart()
    {
        if (_result is null || _result.ByCategory.Count == 0)
            return (MarkupString)"";

        const int barH    = 26;
        const int gapY    = 8;
        const int labelW  = 150;
        const int maxBarW = 240;

        var sorted = _result.ByCategory.OrderByDescending(c => c.F1).ToList();
        int svgH   = sorted.Count * (barH + gapY);

        var sb = new StringBuilder();
        sb.Append($"<svg class=\"acc-bar-svg\" viewBox=\"0 0 460 {svgH}\" xmlns=\"http://www.w3.org/2000/svg\">");

        for (int i = 0; i < sorted.Count; i++)
        {
            var cat  = sorted[i];
            int y    = i * (barH + gapY);
            int bw   = (int)(cat.F1 * maxBarW);
            var fill = cat.F1 >= 0.75f ? "#4caf50" : cat.F1 >= 0.50f ? "#ff9800" : "#f44336";
            var lbl  = System.Web.HttpUtility.HtmlEncode(TruncLabel(cat.Category, 18));
            var pct  = System.Web.HttpUtility.HtmlEncode(cat.F1.ToString("P0"));

            sb.Append($"<text x=\"0\" y=\"{y + barH - 7}\" font-size=\"12\" fill=\"#9e9e9e\" font-family=\"'Fira Code',monospace\">{lbl}</text>");
            sb.Append($"<rect x=\"{labelW}\" y=\"{y + 2}\" width=\"{bw}\" height=\"{barH - 4}\" rx=\"4\" fill=\"{fill}\" opacity=\"0.85\"/>");
            sb.Append($"<text x=\"{labelW + bw + 6}\" y=\"{y + barH - 7}\" font-size=\"12\" fill=\"#e0e0e0\" font-family=\"'Fira Code',monospace\">{pct}</text>");
        }

        sb.Append("</svg>");
        return (MarkupString)sb.ToString();
    }

    private static string F1Class(float f1) =>
        f1 >= 0.75f ? "f1-high" : f1 >= 0.50f ? "f1-mid" : "f1-low";

    private static string TruncLabel(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";
}
